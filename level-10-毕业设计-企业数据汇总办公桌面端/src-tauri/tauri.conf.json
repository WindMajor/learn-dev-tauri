{
  "productName": "DataHub Desktop",
  "version": "1.0.0",
  "identifier": "com.learn.dev.datahub-desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "DataHub Desktop - 企业数据汇总",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "center": true,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost https://api.example.com; img-src 'self' data: asset: https://asset.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "./entitlements.plist",
      "minimumSystemVersion": "11.0"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "fixedInstallerRuntimes"
      },
      "wix": {
        "language": "zh-CN"
      },
      "nsis": {
        "installMode": "currentUser",
        "languages": ["SimpChinese", "English"]
      }
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0", "libayatana-appindicator3-1"]
      }
    }
  },
  "plugins": {
    "dialog": {},
    "fs": {
      "scope": {
        "allow": ["$HOME/Documents/**", "$HOME/Desktop/**", "$HOME/Downloads/**", "$TEMP/**"],
        "deny": ["**/.env", "**/.ssh/**", "**/id_rsa*"]
      }
    },
    "notification": {},
    "global-shortcut": {},
    "updater": {
      "endpoints": ["https://releases.datahub.example.com/updater/{{target}}/{{current_version}}"],
      "pubkey": "PLACEHOLDER_PUBLIC_KEY",
      "windows": { "installMode": "basicUi" }
    },
    "shell": {
      "scope": [
        { "name": "node", "cmd": "node", "args": true },
        { "name": "python3", "cmd": "python3", "args": true }
      ]
    }
  }
}
